---
export interface Props {
  title?: string;
  lang?: string;
}
const { title = 'Atman — Villa Rospigliosi, Vinci', lang = 'it' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ristorante Atman — Cucina gastronomica d'autore a Villa Rospigliosi, Vinci. Una stella Michelin." />
    <title>{title}</title>
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
  </head>
  <body>
    <slot />
  </body>
</html>
